# Supabase — copia este archivo a `.env` y rellena tus credenciales.
# Encuéntralas en: Supabase Dashboard → Project Settings → API
# La clave "anon" es pública por diseño (se incluye en el bundle del cliente);
# la seguridad real depende de tus políticas RLS. NUNCA pongas aquí la service_role key.

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
